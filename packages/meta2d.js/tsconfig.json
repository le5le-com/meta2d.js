{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "moduleResolution": "node",
    "module": "esnext",
    "target": "esnext",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports":true,
      "paths": {
      "@meta2d/*": ["./packages/*"],
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
